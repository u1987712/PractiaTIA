{
    "m_SGVersion": 1,
    "m_Type": "UnityEditor.ShaderGraph.CustomFunctionNode",
    "m_ObjectId": "41f318eaec114f00975b1212bbd3a542",
    "m_Group": {
        "m_Id": ""
    },
    "m_Name": "ToonShading (Custom Function)",
    "m_DrawState": {
        "m_Expanded": true,
        "m_Position": {
            "serializedVersion": "2",
            "x": 2366.3134765625,
            "y": 4801.826171875,
            "width": 308.4444580078125,
            "height": 445.77777099609377
        }
    },
    "m_Slots": [
        {
            "m_Id": "5de67ad5c4094977809d9d5009b19ab4"
        },
        {
            "m_Id": "96e39e6088ba46afa96ba8dabeac7f85"
        },
        {
            "m_Id": "080fc38fef424f42907e92219eb4ff7f"
        },
        {
            "m_Id": "4393222490804737afbecafdc7df5473"
        },
        {
            "m_Id": "80a98d0dacf64ba49454ee5b4b467924"
        },
        {
            "m_Id": "4b54eddd49c849ce8b5dd9aa4f221584"
        },
        {
            "m_Id": "cd833c5d59264c748e5dfbab5c200a6a"
        },
        {
            "m_Id": "6e161e65ae3845f4bb30b835873abd9a"
        },
        {
            "m_Id": "ccb14d98b7174137b621b6d68e6768de"
        }
    ],
    "synonyms": [],
    "m_Precision": 0,
    "m_PreviewExpanded": false,
    "m_DismissedVersion": 0,
    "m_PreviewMode": 0,
    "m_CustomColors": {
        "m_SerializableColors": []
    },
    "m_SourceType": 0,
    "m_FunctionName": "ToonShading",
    "m_FunctionSource": "3e7396943cb5c874dae9b34830502a43",
    "m_FunctionSourceUsePragmas": true,
    "m_FunctionBody": "#ifdef SHADERGRAPH_PREVIEW\nToonRampOutput = float3(0.5,0.5,0);\nDirection = float3(0.5,0.5,0);\n#else\n#if SHADOWS_SCREEN\r\nhalf4 shadowCoord = ComputeScreenPos(ClipSpacePos);\r\n#else\r\nhalf4 shadowCoord = TransformWorldToShadowCoord(WorldPos);\r\n#endif \n#if _MAIN_LIGHT_SHADOWS_CASCADE || _MAIN_LIGHT_SHADOWS\r\nLight light = GetMainLight(shadowCoord);\n#else\nLight light = GetMainLight();\n#endif\nhalf d = dot(Normal, light.direction) * 0.5 + 0.5;\r\t\r\nhalf lightIntensity = smoothstep(ToonRampOffset, ToonRampOffset+ ToonRamp, d + light.shadowAttenuation);\r\n\nToonRampOutput = light.color * (lightIntensity + ToonRampTinting) ;\nDirection = light.direction;\n#endif\n\n"
}

